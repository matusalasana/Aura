  "description": "Aura is a modern full-stack e-commerce platform built with the PERN stack, featuring secure authentication, product management, shopping cart functionality, responsive UI, and a seamless shopping experience.",
  "keywords": [
    "ecommerce",
    "pern",
    "react",
    "nodejs",
    "express",
    "tailwindcss",
    "fullstack",
    "shopping-cart",
