    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "redis": "^5.12.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
